#!/bin/sh
# preinstall — stop a running Boss engine before replacing the bundle.
# Runs as the installing user (per-user domain install).
set -euo pipefail

PID_FILE="/tmp/boss-engine.pid"

if [ -f "$PID_FILE" ]; then
    PID=$(cat "$PID_FILE" 2>/dev/null || true)
    if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
        echo "Stopping running Boss engine (pid $PID)..."
        kill "$PID" || true
        # Give it a moment to exit cleanly
        sleep 1
        kill -9 "$PID" 2>/dev/null || true
    fi
fi

exit 0
