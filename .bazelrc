build --jobs=200
build --disk_cache=~/.cache/bazelcache
build --experimental_disk_cache_gc_max_size=30G
build --experimental_disk_cache_gc_max_age=7d

# Release config: stamps binaries with the git SHA and wires the
# workspace-status.sh script so STABLE_BOSS_GIT_SHA and BUILD_EMBED_LABEL
# flow into the build (design doc Q4 Phase 2).
build:release --workspace_status_command=tools/boss/installer/workspace-status.sh
build:release --stamp

# boss shake credentials: propagate the three env vars that embed the
# GitHub App into the binary at compile time. Values must be set in your
# shell (or via direnv) before running bazel build //tools/boss/cli:boss.
# See tools/boss/cli/README.md for the one-time developer setup instructions.
#
# --action_env is kept for belt-and-suspenders (non-rust actions, tooling).
# --define supplies the values to the rustc_env Make-variable expansion on
# the rust_binary target; rules_rust does not forward --action_env into the
# rustc compile action's env or cache key, but --define IS part of the key.
# Empty defaults here mean dev builds compile cleanly; the release pipeline
# overrides via --define=BOSS_SHAKE_APP_ID="$BOSS_SHAKE_APP_ID" etc.
build --action_env=BOSS_SHAKE_APP_ID
build --action_env=BOSS_SHAKE_INSTALLATION_ID
build --action_env=BOSS_SHAKE_PRIVATE_KEY_PEM
build --define=BOSS_SHAKE_APP_ID=
build --define=BOSS_SHAKE_INSTALLATION_ID=
build --define=BOSS_SHAKE_PRIVATE_KEY_PEM=

