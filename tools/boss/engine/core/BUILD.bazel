# Shard: coordinator + runner + external_tracker + live_status* +
#        nudge_breaker + build_info (330 tests)
rust_test(
    name = "engine_lib_test_coordinator",
    size = "small",
    timeout = "moderate",
    args = [
        "coordinator::",
        "runner::",
        "external_tracker::",
        "live_status::",
        "live_status_loop::",
        "live_status_redact::",
        # nudge_breaker is pure in-memory (no global state) and is the
        # auto-nudge sibling of completion; group it here rather than
        # with a global-state-sharing shard (audit/worker_setup).
        "nudge_breaker::",
        "build_info::",
    ],
    crate = ":engine_lib",
    edition = "2024",
    env = {
        "HOME": "/tmp",
        # Provide a non-empty boss-event path so runner tests that call
        # boss_event_binary() without an injected override don't panic in
        # the Bazel sandbox (no runfiles, no stable bin dir, no sibling).
        # The env-override branch returns this without an existence check,
        # so it works even though /opt/boss/bin/boss-event doesn't exist on
        # CI agents. Tests that assert on the actual baked path inject a
        # real temp file via PaneSpawnRunner::set_boss_event_path() instead.
        "BOSS_EVENT_BIN": "/opt/boss/bin/boss-event",
    },
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    deps = all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

