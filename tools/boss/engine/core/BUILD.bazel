load("@mono_crates//:defs.bzl", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

rust_library(
    name = "engine_lib",
    srcs = glob(
        ["src/**/*.rs"],
        # Keep the library in lockstep with the module tree: a hand-maintained
        # explicit list silently drifts when a new `mod` file is added (it is
        # then absent from rustc's inputs -> E0583). Every other boss crate globs.
        exclude = [
            # Crate root of the `engine` rust_binary below, not the library.
            "src/main.rs",
        ],
    ),
    compile_data = [
        "remote/boss-remote-run.sh",
        # Stamped build-info constants (BOSS_VERSION, BOSS_GIT_SHA, BOSS_BUILD_TIME).
        # Referenced via include!(env!("BOSS_BUILD_INFO_RS")) in build_info_stamp module.
        "//tools/boss/installer:build_info_rs",
    ],
    crate_name = "boss_engine",
    crate_root = "src/lib.rs",
    edition = "2024",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    rustc_env = {
        # Absolute path to the generated build-info constants file.
        # rules_rust prefixes $(execpath) values with ${pwd} and resolves
        # them to absolute filesystem paths before invoking rustc.
        "BOSS_BUILD_INFO_RS": "$(execpath //tools/boss/installer:build_info_rs)",
    },
    visibility = [
        "//tools/boss/bossctl:__pkg__",
        "//tools/boss/cli:__pkg__",
        "//tools/boss/client:__pkg__",
    ],
    deps = [
        "//lib/rust/git_utils",
        "//tools/boss/claude_client",
        "//tools/boss/engine/automation-dedup",
        "//tools/boss/engine/automation-schedule",
        "//tools/boss/engine/ci-log-reader",
        "//tools/boss/engine/conflict-diagnosis",
        "//tools/boss/engine/day-rotated-log",
        "//tools/boss/engine/deterministic-resolvers",
        "//tools/boss/engine/driver",
        "//tools/boss/engine/editorial",
        "//tools/boss/engine/effort",
        "//tools/boss/engine/feature-flags",
        "//tools/boss/engine/gh-invocation",
        "//tools/boss/engine/live-status-redact",
        "//tools/boss/engine/metrics",
        "//tools/boss/engine/planner-validation",
        "//tools/boss/engine/pr-template",
        "//tools/boss/engine/ssh-transport",
        "//tools/boss/engine/transcript-markdown:transcript_markdown",
        "//tools/boss/engine/transcript-tail",
        "//tools/boss/engine/transient-error",
        "//tools/boss/engine/utils",
        "//tools/boss/github",
        "//tools/boss/github_tracker",
        "//tools/boss/log-files",
        "//tools/boss/protocol",
    ] + all_crate_deps(normal = True),
)

rust_binary(
    name = "engine",
    srcs = ["src/main.rs"],
    # Ship the boss-event hook shim alongside the engine binary so
    # PaneSpawnRunner can resolve it via runfiles at runtime. Without
    # this dep, `bazel run //tools/boss/engine/core:engine` builds only
    # the engine and worker `settings.json` ends up referencing
    # `boss-event` as a bare name that isn't on the worker's
    # sanitized PATH — every hook fires `command not found`.
    data = ["//tools/boss/event-shim:boss-event"],
    edition = "2024",
    proc_macro_deps = all_crate_deps(proc_macro = True),
    visibility = [
        "//tools/boss/app-macos:__pkg__",
        "//tools/boss/installer:__pkg__",
    ],
    deps = [
        ":engine_lib",
        "//tools/boss/build-info",
        "//tools/boss/log-files",
    ] + all_crate_deps(normal = True),
)

# engine_lib_test is ONE rust_test with native Bazel sharding
# (shard_count = 11), enabled by the rules_rust#3774 backport patch in
# //third_party/patches (see MODULE.bazel single_version_override). One
# cfg(test) compile of the crate + 11 parallel shard executions, vs the
# previous layout's 4 filter-partitioned rust_test targets = 4 full compiles.
# See docs/investigations/rust-test-sharding-engine-lib-test.md (T2856) for
# the correctness gate and before/after measurements this adoption is based on.
#
# size = "small" / timeout = "moderate" (300 s):
#   linux-amd64 CI runners run ~6-7x slower than macOS dev boxes, so the
#   60 s default for size="small" is too tight.
# env:
#   HOME=/tmp — Bazel's sandbox does not inherit HOME; tests that call
#     cube_default_workspace_root_for_test need a stable sentinel value.
#   BOSS_EVENT_BIN — non-empty boss-event path so runner tests that call
#     boss_event_binary() without an injected override don't panic in the
#     Bazel sandbox (union of the previous per-shard envs; harmless for
#     tests that don't read it).
#
# Single-test dev loop: `bazel test --test_arg=--exact --test_arg=name` does
# NOT work here (sharding forces --exact name matching per-shard, so a lone
# test name only reaches whichever shard it hashes into, and `bazel run` on a
# sharded test is refused outright: "'run' only works with tests with one
# shard"). Instead, disable sharding for the run and exec the binary directly:
#   bazel run --test_sharding_strategy=disabled \
#       //tools/boss/engine/core:engine_lib_test -- --exact path::to::test_name

rust_test(
    name = "engine_lib_test",
    size = "small",
    timeout = "moderate",
    crate = ":engine_lib",
    edition = "2024",
    env = {
        "BOSS_EVENT_BIN": "/opt/boss/bin/boss-event",
        "HOME": "/tmp",
    },
    experimental_enable_sharding = True,
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
    shard_count = 11,
    deps = all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
)

