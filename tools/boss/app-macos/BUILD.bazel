load("@build_bazel_rules_apple//apple:macos.bzl", "macos_application", "macos_unit_test")
load("@build_bazel_rules_swift//swift:swift.bzl", "swift_library")
load("//tools/boss/installer:pkg.bzl", "boss_short_version_plist")

package(default_visibility = ["//visibility:private"])

exports_files([
    "Package.resolved",
    "Package.swift",
    "ghosttykit.BUILD",
])

swift_library(
    name = "boss_mac_app_lib",
    srcs = glob(["Sources/**/*.swift"]),
    copts = [
        # Mirror the swiftSettings define in Package.swift so @inlinable
        # Textual APIs (e.g. .textual.textSelection) expand correctly here.
        "-DTEXTUAL_ENABLE_TEXT_SELECTION",
        # Match Package.swift's `swift-tools-version: 6.2`. Without this,
        # bazel compiles under the rules_swift default (Swift 5 mode) and
        # silently skips the strict-concurrency diagnostics that
        # `swift run` would fire. CI then passes on changes that break
        # the dev workflow — see #601 (LogViewer.swift global formatter)
        # for a recent example.
        "-swift-version",
        "6",
        "-strict-concurrency=complete",
    ],
    module_name = "Boss",
    deps = [
        "//tools/boss/app-macos/Sources/UpdateCore",
        "@ghostty_kit//:GhosttyKit",
        "@swiftpkg_textual//:Textual",
    ],
)

# BossTests is sharded across four independent macos_unit_test targets so
# each one fits comfortably inside the "small" (60s) timeout as the suite
# grows (see CI timeout in exec_18bf0a6008fc0cc0_170). rules_apple's default
# macos test runner (apple/testing/default_runner) does not implement Bazel's
# native shard_count sharding protocol (no TEST_SHARD_INDEX/TEST_TOTAL_SHARDS
# handling), so `shard_count` on a single macos_unit_test is a no-op here —
# splitting into separate targets is the mechanism that actually parallelizes
# test execution for this rule.
#
# CommentsTests.swift + TranscriptViewTests.swift are split into their own
# shard because CommentLayerTests alone accounts for ~85% of total XCTest
# runtime (~12.8s of ~14.9s measured locally); bundling it with anything else
# risks that shard alone approaching the timeout. The remaining files are
# split into three buckets balanced by source line count.
#
# Shard3 is a catch-all glob rather than a fourth hand-listed file set: the
# first three shards' file lists are named below and fed into both their own
# srcs and shard3's glob exclude, so those two views of the same lists can
# never drift apart. Any new file added under Tests/BossTests/ therefore
# automatically lands in shard3 and runs, instead of silently being skipped
# by every shard (a false green) because no one remembered to hand-list it.
_COMMENTS_TRANSCRIPT_SHARD_SRCS = [
    "Tests/BossTests/CommentsTests.swift",
    "Tests/BossTests/TranscriptViewTests.swift",
]

_SHARD1_SRCS = [
    "Tests/BossTests/APIKeyStoreTests.swift",
    "Tests/BossTests/ApplyAttentionGroupsListTests.swift",
    "Tests/BossTests/DesignsTests.swift",
    "Tests/BossTests/EngineAutoChoreKanbanTests.swift",
    "Tests/BossTests/KanbanExternalRefLinkTests.swift",
    "Tests/BossTests/KanbanRepoChipTests.swift",
    "Tests/BossTests/KanbanShortIDBadgeTests.swift",
    "Tests/BossTests/LogTailWindowTests.swift",
    "Tests/BossTests/LogViewerTailPerfTests.swift",
    "Tests/BossTests/MainThreadStallDiagnosticsTests.swift",
    "Tests/BossTests/OpenQuestionGroupsForDocPathTests.swift",
    "Tests/BossTests/PopulationTimingDiagnosticsTests.swift",
    "Tests/BossTests/ProductCreateFormCopyTests.swift",
    "Tests/BossTests/ProjectDesignDocAffordanceTests.swift",
    "Tests/BossTests/ProjectShortIDBadgeTests.swift",
    "Tests/BossTests/ReviewColumnOrderingTests.swift",
    "Tests/BossTests/WorkBlockedBadgeTests.swift",
    "Tests/BossTests/WorkerProcessKillerTests.swift",
    "Tests/BossTests/WorkersWorkspaceModelTests.swift",
]

_SHARD2_SRCS = [
    "Tests/BossTests/ActiveProductsFilterTests.swift",
    "Tests/BossTests/ActivityLogTests.swift",
    "Tests/BossTests/AttentionGroupsListRaceTests.swift",
    "Tests/BossTests/EffortChipTests.swift",
    "Tests/BossTests/EngineClientLargeMessageFramingTests.swift",
    "Tests/BossTests/EngineHealthBannerTests.swift",
    "Tests/BossTests/EngineUnreachableErrorRoutingTests.swift",
    "Tests/BossTests/ExternalTrackerAttentionTests.swift",
    "Tests/BossTests/ExternalTrackerTests.swift",
    "Tests/BossTests/GitHubAuthTests.swift",
    "Tests/BossTests/GitHubContentFetcherTests.swift",
    "Tests/BossTests/InvestigationKanbanTests.swift",
    "Tests/BossTests/KanbanFilterBannerTests.swift",
    "Tests/BossTests/KanbanInRevisionWarningTests.swift",
    "Tests/BossTests/KanbanPRLinkLabelTests.swift",
    "Tests/BossTests/ProjectArchiveContextMenuTests.swift",
    "Tests/BossTests/ProjectNavigatorCountBadgeTests.swift",
    "Tests/BossTests/WorkDependencyKanbanTests.swift",
    "Tests/BossTests/WorkItemRepoRowTests.swift",
]

macos_unit_test(
    name = "BossTestsCommentsTranscript",
    size = "small",
    minimum_os_version = "15.0",
    deps = [":boss_mac_app_tests_comments_transcript_lib"],
)

swift_library(
    name = "boss_mac_app_tests_comments_transcript_lib",
    testonly = True,
    srcs = _COMMENTS_TRANSCRIPT_SHARD_SRCS,
    copts = ["-DTEXTUAL_ENABLE_TEXT_SELECTION"],
    module_name = "BossTestsCommentsTranscript",
