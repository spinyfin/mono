macos_unit_test(
    name = "BossTestsShard1",
    size = "small",
    minimum_os_version = "15.0",
    deps = [":boss_mac_app_tests_shard1_lib"],
)

swift_library(
    name = "boss_mac_app_tests_shard1_lib",
    testonly = True,
    srcs = _SHARD1_SRCS,
    copts = ["-DTEXTUAL_ENABLE_TEXT_SELECTION"],
