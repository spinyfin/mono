<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleDisplayName</key>
    <string>Boss</string>
    <key>CFBundleExecutable</key>
    <string>Boss</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Boss</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <!-- CFBundleVersion and CFBundleShortVersionString are stamped by boss_version_plist
         in BUILD.bazel via STABLE_BOSS_BASE_VERSION and STABLE_BOSS_VERSION from
         workspace-status.sh. Fallbacks: "0.0.0" / "dev" when not stamped. -->
    <key>LSMinimumSystemVersion</key>
    <string>15.0</string>
    <key>NSPrincipalClass</key>
    <string>NSApplication</string>
    <!-- net.daringfireball.markdown is already a system-declared UTI on
         macOS 15+ (imported by Notes/Xcode, tags .md/.markdown, conforms
         to public.plain-text) — no UTImportedTypeDeclarations needed
         here, just reference it. Boss only renders markdown (Textual)
         and never writes back to the file, so CFBundleTypeRole is
         Viewer. LSHandlerRank is Alternate: Boss should be selectable
         from Finder's "Open With" and settable as the user's default,
         but must not auto-claim default status away from the user's
         existing markdown app on install. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Markdown Document</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>net.daringfireball.markdown</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
